{
  "name": "neural-drive-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Optional REST API backend for Neural Drive Lab — stores training run history",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test tests/*.test.js",
    "test:coverage": "node --experimental-test-coverage --test tests/*.test.js",
    "lint": "npx eslint src tests",
    "lint:fix": "npx eslint src tests --fix",
    "fmt": "npx prettier --write src tests",
    "fmt:check": "npx prettier --check src tests",
    "ci": "npm run lint && npm run fmt:check && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "9.20.0",
    "eslint": "9.20.0",
    "prettier": "3.4.2"
  }
}
